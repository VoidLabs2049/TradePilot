#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 3 ]; then
  cat <<'USAGE'
Usage:
  bash scripts/view-etf-aw ETF_CODE START_DATE END_DATE [options]

Examples:
  bash scripts/view-etf-aw 510300.SH 2026-05-01 2026-05-31
  bash scripts/view-etf-aw 510300 2026-05-01 2026-05-31
  bash scripts/view-etf-aw 510300.SH 2026-04-01 2026-05-31 --dataset snapshot
  bash scripts/view-etf-aw 159845.SZ 2026-05-01 2026-05-31 --csv /tmp/159845.csv

Options are passed to:
  python -m tradepilot.etl.view_etf_aw
USAGE
  exit 2
fi

python -m tradepilot.etl.view_etf_aw "$@"
